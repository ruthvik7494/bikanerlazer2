{
  "rewrites": [
    {
      "source": "/wp-json/:path*",
      "destination": "https://admin.bikanerlaser.com/wp-json/:path*"
    },
    {
      "source": "/wp-content/:path*",
      "destination": "https://admin.bikanerlaser.com/wp-content/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
